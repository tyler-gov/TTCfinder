  <style>
:root{--bg:#07090d;--surface:#0d1117;--surface2:#111820;--border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.12);--text:#dde8f5;--muted:#5f7a96;--accent:#e8343a;--accent2:#ff6b2b;--good:#22c55e;--warn:#eab308;--bad:#ef4444;--mono:'Space Mono','Courier New',monospace;--display:'Syne',sans-serif;--radius-sm:8px;--radius:14px}
*,*::before,*::after{box-sizing:border-box}html,body{height:100%;margin:0}
body{font-family:var(--mono);background:var(--bg);color:var(--text);overflow:hidden}
body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:9999;opacity:.025;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");background-size:200px}
.app{height:100vh;display:flex;flex-direction:column}
.header{display:flex;align-items:center;justify-content:space-between;padding:12px 20px;gap:16px;border-bottom:1px solid var(--border);background:rgba(7,9,13,0.88);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);flex-shrink:0}
.header-left{display:flex;align-items:center;gap:16px}
.logo-badge{display:flex;align-items:center;gap:8px;padding:6px 12px 6px 8px;background:var(--accent);border-radius:var(--radius-sm)}
.logo-icon{width:20px;height:20px;border-radius:4px;background:rgba(0,0,0,0.3);display:flex;align-items:center;justify-content:center;font-size:11px}
.logo-text{font-family:var(--display);font-weight:900;font-size:14px;letter-spacing:1.5px;color:#fff}
.h1{font-family:var(--display);font-size:16px;font-weight:800}.sub{font-size:10px;color:var(--muted);letter-spacing:.3px;margin-top:1px}
.mode-badge{display:flex;align-items:center;gap:6px;padding:5px 10px;border:1px solid var(--border2);border-radius:999px;font-size:10px;font-family:var(--display);font-weight:700;letter-spacing:.5px;color:var(--muted);transition:border-color .4s,color .4s}
.mode-badge.live{border-color:rgba(34,197,94,0.4);color:var(--good)}.mode-badge.poll{border-color:rgba(234,179,8,0.35);color:var(--warn)}.mode-badge.error{border-color:rgba(239,68,68,0.35);color:var(--bad)}
.mode-dot{width:6px;height:6px;border-radius:50%;background:currentColor}
.mode-badge.live .mode-dot{animation:livepulse 2s ease-in-out infinite}
@keyframes livepulse{0%,100%{opacity:1}50%{opacity:.3}}
.status{display:flex;align-items:center;gap:10px;padding:8px 14px;border:1px solid var(--border);border-radius:var(--radius);background:rgba(13,17,23,0.6)}
.dot{width:8px;height:8px;border-radius:50%;background:var(--warn);box-shadow:0 0 0 3px rgba(234,179,8,0.2);flex-shrink:0;transition:background .3s,box-shadow .3s}
.dot.good{background:var(--good);box-shadow:0 0 0 3px rgba(34,197,94,0.2)}.dot.bad{background:var(--bad);box-shadow:0 0 0 3px rgba(239,68,68,0.2)}.dot.pulse{animation:pulse 1.8s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.status-text{font-size:11px;font-weight:700;font-family:var(--display);letter-spacing:.3px}.status-meta{font-size:10px;color:var(--muted)}
.panel{padding:12px 20px;border-bottom:1px solid var(--border);background:rgba(13,17,23,0.6);flex-shrink:0}
.filters{display:grid;grid-template-columns:1fr 1fr 1fr 2fr 120px 90px 90px;gap:8px;align-items:end}
.field label{display:block;font-size:9px;color:var(--muted);letter-spacing:.8px;text-transform:uppercase;margin-bottom:5px}
.field input,.field select{width:100%;padding:9px 10px;border:1px solid var(--border2);background:rgba(7,9,13,0.6);color:var(--text);border-radius:var(--radius-sm);font-family:var(--mono);font-size:11px;outline:none;transition:border-color .15s,background .15s}
.field input:focus,.field select:focus{border-color:var(--accent);background:rgba(232,52,58,0.04)}
.field input::placeholder{color:var(--muted)}.field.wide{grid-column:4/5}
.btn{width:100%;padding:9px 10px;border-radius:var(--radius-sm);border:1px solid var(--accent);background:rgba(232,52,58,0.12);color:var(--text);cursor:pointer;font-family:var(--display);font-weight:800;font-size:12px;letter-spacing:.4px;transition:background .15s,transform .1s}
.btn:hover{background:rgba(232,52,58,0.22)}.btn:active{transform:scale(.97)}.btn.ghost{border-color:var(--border2);background:rgba(7,9,13,0.4)}.btn.ghost:hover{background:rgba(255,255,255,0.05)}
.stats{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap;align-items:center}
.pill{display:flex;align-items:center;gap:6px;padding:5px 12px;border:1px solid var(--border);border-radius:999px;font-size:11px;color:var(--muted);background:rgba(13,17,23,0.5)}
.pill strong{color:var(--text);font-family:var(--display);font-weight:700}
.help{margin-top:10px;border:1px solid var(--border);border-radius:var(--radius);background:rgba(7,9,13,0.4);overflow:hidden}
.help summary{cursor:pointer;padding:9px 12px;font-size:11px;font-weight:700;font-family:var(--display);color:var(--muted);list-style:none;display:flex;align-items:center;gap:6px;user-select:none;transition:color .15s}
.help summary:hover{color:var(--text)}.help summary::before{content:'▶';font-size:8px;transition:transform .2s}.help[open] summary::before{transform:rotate(90deg)}.help summary::-webkit-details-marker{display:none}
.help-body{padding:0 12px 12px;color:var(--muted);font-size:11px;line-height:1.6}.help-body p{margin:8px 0 0}.help-body code{color:var(--accent2);font-family:var(--mono)}
pre.code{margin:8px 0 0;padding:10px 12px;border:1px solid var(--border2);border-radius:var(--radius-sm);background:rgba(7,9,13,0.7);color:#a8c4e0;font-family:var(--mono);font-size:10px;line-height:1.5;overflow:auto;white-space:pre}
.main{flex:1;min-height:0;display:grid;grid-template-columns:1fr 360px}
#map{height:100%;width:100%}
.map-tiles{filter:invert(1) hue-rotate(180deg) brightness(.85) contrast(1.05)}
.leaflet-popup-content-wrapper{background:var(--surface2)!important;border:1px solid var(--border2)!important;border-radius:var(--radius)!important;color:var(--text)!important;box-shadow:0 8px 32px rgba(0,0,0,.6)!important;font-family:var(--mono)!important}
.leaflet-popup-tip{background:var(--surface2)!important}.leaflet-popup-content{margin:12px 14px!important}
.sidebar{border-left:1px solid var(--border);background:rgba(7,9,13,0.72);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);display:flex;flex-direction:column;min-height:0}
.sidebar-header{display:flex;align-items:center;justify-content:space-between;padding:11px 14px;border-bottom:1px solid var(--border);flex-shrink:0}
.h2{font-family:var(--display);font-size:13px;font-weight:900;letter-spacing:.8px;text-transform:uppercase}
.list{padding:10px;overflow-y:auto;display:flex;flex-direction:column;gap:8px;flex:1;scrollbar-width:thin;scrollbar-color:var(--border2) transparent}
.card{border:1px solid var(--border);background:rgba(13,17,23,0.7);border-radius:var(--radius);padding:10px 12px;cursor:pointer;transition:border-color .15s,background .15s,transform .12s}
.card:hover{border-color:var(--accent);background:rgba(232,52,58,0.05);transform:translateX(2px)}
.card-top{display:flex;justify-content:space-between;gap:8px;align-items:flex-start}
.card-route{font-family:var(--display);font-size:22px;font-weight:900;line-height:1;letter-spacing:-.5px}
.card-vehicle{font-size:10px;color:var(--muted);text-align:right}.card-vehicle strong{display:block;font-size:13px;color:var(--text)}
.card-grid{margin-top:8px;display:grid;grid-template-columns:1fr 1fr;gap:4px 10px}
.card-kv{display:flex;gap:5px;font-size:10px;overflow:hidden}.k{color:var(--muted);flex-shrink:0}.v{color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.age-badge{display:inline-block;padding:1px 5px;border-radius:4px;font-size:9px;font-weight:700;background:rgba(34,197,94,0.15);color:var(--good)}
.age-badge.warn{background:rgba(234,179,8,0.15);color:var(--warn)}.age-badge.old{background:rgba(239,68,68,0.12);color:var(--bad)}
.empty-state{padding:40px 16px;text-align:center;color:var(--muted);font-size:11px}.empty-state .icon{font-size:32px;display:block;margin-bottom:8px}
.footer{padding:8px 20px;border-top:1px solid var(--border);display:flex;justify-content:space-between;gap:12px;color:var(--muted);font-size:10px;background:rgba(7,9,13,0.7);flex-shrink:0;letter-spacing:.3px}
  </style>
</head>
<body>
<div class="app">
  <header class="header">
    <div class="header-left">
      <div class="logo-badge"><div class="logo-icon">&#x1F68C;</div><div class="logo-text">TTC</div></div>
      <div><div class="h1">TTC Where</div><div class="sub">Live vehicle positions &middot; GTFS-RT feed</div></div>
    </div>
    <div style="display:flex;align-items:center;gap:10px">
      <div id="modeBadge" class="mode-badge poll"><div class="mode-dot"></div><span id="modeLabel">Connecting&hellip;</span></div>
      <div class="status">
        <div id="statusDot" class="dot pulse"></div>
        <div><div id="statusText" class="status-text">Booting&hellip;</div><div id="statusMeta" class="status-meta">&ndash;</div></div>
      </div>
    </div>
  </header>

  <section class="panel">
    <div class="filters">
      <div class="field"><label for="routeId">Route ID</label><input id="routeId" placeholder="e.g. 504, 29, 1" autocomplete="off"/></div>
      <div class="field"><label for="vehicleId">Vehicle ID</label><input id="vehicleId" placeholder="exact match" autocomplete="off"/></div>
      <div class="field"><label for="tripId">Trip ID</label><input id="tripId" placeholder="exact match" autocomplete="off"/></div>
      <div class="field wide"><label for="quick">Quick search</label><input id="quick" placeholder="route / trip / vehicle / label / stop&hellip;" autocomplete="off"/></div>
      <div class="field"><label for="refreshMs">Refresh (poll)</label><select id="refreshMs"><option value="3000">3 s</option><option value="5000" selected>5 s</option><option value="10000">10 s</option><option value="20000">20 s</option></select></div>
      <div class="field"><label>&nbsp;</label><button id="centerOnToronto" class="btn">Center</button></div>
      <div class="field"><label>&nbsp;</label><button id="clearFilters" class="btn ghost">Clear</button></div>
    </div>
    <div class="stats">
      <div class="pill"><span>Showing</span>&nbsp;<strong id="showingCount">0</strong></div>
      <div class="pill"><span>Total</span>&nbsp;<strong id="totalCount">0</strong></div>
      <div class="pill"><span>Last fetch</span>&nbsp;<strong id="lastFetch">&ndash;</strong></div>
      <div class="pill"><span>Endpoint</span>&nbsp;<strong id="apiLabel">&ndash;</strong></div>
    </div>
    <details class="help">
      <summary>Setup &amp; local testing guide</summary>
      <div class="help-body">
        <p><strong>How to test this app</strong></p>
        <p>CodePen does NOT work for this app &mdash; it blocks direct fetch to external APIs and can't decode protobuf. Instead:</p>
        <p><strong>Option A &mdash; Open the HTML file directly</strong> (simplest): Save this file to your computer, open it in Chrome/Firefox via <code>File &rarr; Open</code> (<code>file:///…/ttc-where.html</code>). Set <code>API_BASE</code> in the JS to your deployed Cloudflare Worker URL.</p>
        <p><strong>Option B &mdash; Local dev server</strong>: Run <code>npx serve .</code> or use VS Code Live Server. Open <code>http://localhost:3000/ttc-where.html</code>. Same: set <code>API_BASE</code> to your Worker.</p>
        <p><strong>Option C &mdash; Run a local proxy too</strong>: If you want to run the proxy locally, install Node and run <code>npx wrangler dev</code> inside your Worker project. Set <code>API_BASE = "http://localhost:8787"</code>.</p>
        <p><strong>Connection priority (auto)</strong>: SSE push &rarr; WebSocket &rarr; REST polling. Cascades automatically.</p>
        <p><strong>Cloudflare Worker (polling endpoint)</strong> &mdash; add <code>gtfs-realtime-bindings</code>:</p>
<pre class="code">import GtfsRealtimeBindings from "gtfs-realtime-bindings";
export default {
  async fetch(request) {
    if (request.method === "OPTIONS") return new Response(null,{status:204,headers:cors()});
    const url = new URL(request.url);
    if (!url.pathname.endsWith("/vehicles")) return new Response("Not Found",{status:404,headers:cors()});
    const resp = await fetch("https://bustime.ttc.ca/gtfsrt/vehicles?debug",{headers:{Accept:"application/x-protobuf"}});
    if (!resp.ok) return json({error:"Upstream error",status:resp.status},502);
    const feed = GtfsRealtimeBindings.transit_realtime.FeedMessage.decode(new Uint8Array(await resp.arrayBuffer()));
    const now = Date.now();
    const entities = (feed.entity||[]).filter(e=>e.vehicle?.position).map(e=>{
      const v=e.vehicle;
      return {entity_id:e.id??null,trip:{trip_id:v.trip?.trip_id??null,route_id:v.trip?.route_id??null,direction_id:v.trip?.direction_id??null},vehicle:{vehicle_id:v.vehicle?.id??null,label:v.vehicle?.label??null},position:{lat:v.position.latitude,lon:v.position.longitude,bearing:v.position.bearing??null,speed:v.position.speed??null},stop_id:v.stop_id??null,timestamp:v.timestamp?Number(v.timestamp)*1000:null,age_ms:v.timestamp?now-Number(v.timestamp)*1000:null};
    });
    return json({fetched_at:new Date().toISOString(),count:entities.length,entities});
  }
};
function cors(){return{"Access-Control-Allow-Origin":"*","Access-Control-Allow-Methods":"GET,OPTIONS","Access-Control-Allow-Headers":"Content-Type","Cache-Control":"no-store","Content-Type":"application/json;charset=utf-8"}}
function json(obj,status=200){return new Response(JSON.stringify(obj),{status,headers:cors()})}</pre>
      </div>
    </details>
  </section>

  <main class="main">
    <div id="map"></div>
    <aside class="sidebar">
      <div class="sidebar-header">
        <div class="h2">Vehicles</div>
        <button id="fitToMarkers" class="btn ghost" style="width:auto;padding:6px 12px;font-size:11px">Fit view</button>
