<script>
/* TTC Where v3 — arrow markers + clustering + SSE/WS/poll cascade */

const API_BASE  = "https://YOUR-PROXY.example.com"; // <- SET THIS
const WS_URL    = ""; // optional override, else derived from API_BASE
const AGE_WARN  = 30000;
const AGE_OLD   = 90000;
const MARKER_SZ = 28;
const TORONTO   = [43.6532, -79.3832];

const $   = id => document.getElementById(id);
const els = {
  statusDot:$("statusDot"),statusText:$("statusText"),statusMeta:$("statusMeta"),
  modeBadge:$("modeBadge"),modeLabel:$("modeLabel"),
  routeId:$("routeId"),vehicleId:$("vehicleId"),tripId:$("tripId"),quick:$("quick"),
  refreshMs:$("refreshMs"),showingCount:$("showingCount"),totalCount:$("totalCount"),
  lastFetch:$("lastFetch"),apiLabel:$("apiLabel"),centerOnToronto:$("centerOnToronto"),
  clearFilters:$("clearFilters"),fitToMarkers:$("fitToMarkers"),list:$("list")
};

let map, clusterGroup, allVehicles=[], visibleMarkers=[], fetchTimer=null;
let eventSource=null, socket=null, connMode="boot";

function setStatus(kind,text,meta="–"){
  els.statusDot.className="dot"+(kind==="warn"?" pulse":"")+(kind!=="warn"?" "+kind:"");
  els.statusText.textContent=text; els.statusMeta.textContent=meta;
}
function setMode(mode){
  connMode=mode;
  const L={sse:"Live · SSE",ws:"Live · WS",poll:"Polling",error:"Error",boot:"…"};
  const C={sse:"live",ws:"live",poll:"poll",error:"error",boot:"poll"};
  els.modeBadge.className="mode-badge "+(C[mode]||"poll");
  els.modeLabel.textContent=L[mode]||mode;
}

function initMap(){
  map=L.map("map",{zoomControl:true}).setView(TORONTO,12);
  L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png",{maxZoom:19,attribution:"&copy; OpenStreetMap contributors",className:"map-tiles"}).addTo(map);
  clusterGroup=L.markerClusterGroup({
    maxClusterRadius:50,spiderfyOnMaxZoom:true,showCoverageOnHover:false,zoomToBoundsOnClick:true,
    iconCreateFunction(cluster){
      const n=cluster.getChildCount(),d=n<10?36:n<50?42:48,r=d/2,fs=n<100?13:11;
      return L.divIcon({
        html:`<svg width="${d}" height="${d}" viewBox="0 0 ${d} ${d}" xmlns="http://www.w3.org/2000/svg"><circle cx="${r}" cy="${r}" r="${r-.5}" fill="rgba(232,52,58,0.18)" stroke="rgba(232,52,58,0.55)" stroke-width="1.5"/><circle cx="${r}" cy="${r}" r="${r-7}" fill="rgba(232,52,58,0.7)"/><text x="${r}" y="${r+fs*.38}" text-anchor="middle" font-family="Syne,sans-serif" font-weight="800" font-size="${fs}" fill="#fff">${n}</text></svg>`,
        className:"",iconSize:[d,d],iconAnchor:[r,r]
      });
    }
  }).addTo(map);
}

function makeIcon(bearing,ageClass){
  const s=MARKER_SZ,r=s/2;
  const fill=ageClass==="warn"?"#eab308":ageClass==="old"?"#ef4444":"#22c55e";
  const ring=ageClass==="warn"?"rgba(234,179,8,0.28)":ageClass==="old"?"rgba(239,68,68,0.28)":"rgba(34,197,94,0.28)";
  const stroke=ageClass==="warn"?"#a16207":ageClass==="old"?"#7f1d1d":"#14532d";
  const hasBrg=bearing!=null&&!isNaN(Number(bearing));
  const rot=hasBrg?Number(bearing):0,op=hasBrg?.9:.22;
  // chevron arrow pointing up: tip at top, notch creates the V cutout at base
  const tipX=r,tipY=r-r*.52,bL=r-r*.30,bR=r+r*.30,bY=r+r*.38,nY=r+r*.06;
  const path=`M${tipX},${tipY} L${bL},${bY} L${r},${nY} L${bR},${bY} Z`;
  const svg=`<svg width="${s}" height="${s}" viewBox="0 0 ${s} ${s}" xmlns="http://www.w3.org/2000/svg" style="display:block;overflow:visible"><circle cx="${r}" cy="${r}" r="${r}" fill="${ring}"/><circle cx="${r}" cy="${r}" r="${r-2.5}" fill="${fill}" stroke="${stroke}" stroke-width="1.2"/><g transform="rotate(${rot} ${r} ${r})" opacity="${op}"><path d="${path}" fill="rgba(0,0,0,0.72)"/></g></svg>`;
  return L.divIcon({html:svg,className:"",iconSize:[s,s],iconAnchor:[r,r],popupAnchor:[0,-r-2]});
}

function buildPopup(v){
  const age=formatAge(v.age_ms),time=v.timestamp?new Date(v.timestamp).toLocaleTimeString():"–";
  const brg=v.position?.bearing!=null?Math.round(v.position.bearing)+"°":"–";
  const spd=v.position?.speed!=null?(v.position.speed*3.6).toFixed(1)+" km/h":"–";
  return `<div style="font-family:'Space Mono',monospace;font-size:11px;line-height:1.75;color:#dde8f5;min-width:215px"><div style="font-family:'Syne',sans-serif;font-size:15px;font-weight:900;margin-bottom:8px;color:#fff">Route ${esc(v.trip?.route_id??"?")} <span style="font-size:11px;font-weight:400;color:#5f7a96">· Veh ${esc(v.vehicle?.vehicle_id??"?")}</span></div><div style="color:#9fb0c4">Trip: ${esc(v.trip?.trip_id??"–")}<br/>Label: ${esc(v.vehicle?.label??"–")}<br/>Stop: ${esc(v.stop_id??"–")}<br/>Bearing: ${brg} &nbsp; Speed: ${spd}<br/>Updated: ${time} <span style="color:#22c55e">(${age} ago)</span></div></div>`;
}

function buildCard(v,ac){
  const age=formatAge(v.age_ms),brg=v.position?.bearing!=null?Math.round(v.position.bearing)+"°":"–",spd=v.position?.speed!=null?(v.position.speed*3.6).toFixed(1)+" km/h":"–";
  return `<div class="card-top"><div class="card-route">${esc(v.trip?.route_id??"–")}</div><div class="card-vehicle"><span>Vehicle</span><strong>${esc(v.vehicle?.vehicle_id??"–")}</strong></div></div><div class="card-grid"><div class="card-kv"><span class="k">Trip</span><span class="v">${esc(v.trip?.trip_id??"–")}</span></div><div class="card-kv"><span class="k">Age</span><span class="v"><span class="age-badge ${ac}">${esc(age)}</span></span></div><div class="card-kv"><span class="k">Bearing</span><span class="v">${brg}</span></div><div class="card-kv"><span class="k">Speed</span><span class="v">${spd}</span></div></div>`;
}

function getFilters(){return{routeId:els.routeId.value.trim(),vehicleId:els.vehicleId.value.trim(),tripId:els.tripId.value.trim(),quick:els.quick.value.trim().toLowerCase()}}

function matchesFilters(v,f){
  if(f.routeId&&str(v.trip?.route_id)!==f.routeId)return false;
  if(f.vehicleId&&str(v.vehicle?.vehicle_id)!==f.vehicleId)return false;
  if(f.tripId&&str(v.trip?.trip_id)!==f.tripId)return false;
  if(f.quick){const h=[v.trip?.route_id,v.trip?.trip_id,v.vehicle?.vehicle_id,v.vehicle?.label,v.stop_id,v.entity_id].map(x=>str(x).toLowerCase()).join("|");if(!h.includes(f.quick))return false}
  return true;
}

function render(){
  const f=getFilters(),filtered=allVehicles.filter(v=>matchesFilters(v,f));
  els.totalCount.textContent=allVehicles.length;els.showingCount.textContent=filtered.length;
  clusterGroup.clearLayers();els.list.innerHTML="";visibleMarkers=[];
  if(!filtered.length){els.list.innerHTML='<div class="empty-state"><span class="icon">&#x1F68C;</span>No vehicles match the current filters.</div>';return}
  const frag=document.createDocumentFragment();
  for(const v of filtered){
    const age=v.age_ms??null,ac=age==null?"":age<AGE_WARN?"":age<AGE_OLD?"warn":"old";
    const marker=L.marker([v.position.lat,v.position.lon],{icon:makeIcon(v.position?.bearing,ac)});
    marker.bindPopup(buildPopup(v),{maxWidth:280});
    clusterGroup.addLayer(marker);visibleMarkers.push(marker);
    const card=document.createElement("div");card.className="card";card.innerHTML=buildCard(v,ac);
    card.addEventListener("click",()=>clusterGroup.zoomToShowLayer(marker,()=>marker.openPopup()));
    frag.appendChild(card);
  }
  els.list.appendChild(frag);
}

function ingest(data){allVehicles=Array.isArray(data.entities)?data.entities:[];els.lastFetch.textContent=new Date().toLocaleTimeString();render()}

function startSSE(){
  const url=`${API_BASE}/vehicles/stream`;
  console.info("[TTC] SSE:",url);
  eventSource=new EventSource(url);
  eventSource.onopen=()=>{setMode("sse");setStatus("good","Live · SSE","Push stream active");stopPolling()};
  eventSource.onmessage=evt=>{try{ingest(JSON.parse(evt.data));setStatus("good","Live · SSE",allVehicles.length+" vehicles")}catch(e){}};
  eventSource.onerror=()=>{eventSource.close();eventSource=null;tryWS()};
}

function tryWS(){
  const url=WS_URL||API_BASE.replace(/^http/,"ws")+"/vehicles/ws";
  console.info("[TTC] WS:",url);
  try{socket=new WebSocket(url)}catch(e){startPolling();return}
  const t=setTimeout(()=>{if(socket&&socket.readyState!==WebSocket.OPEN){socket.close();socket=null;startPolling()}},4000);
  socket.onopen=()=>{clearTimeout(t);setMode("ws");setStatus("good","Live · WS","WebSocket connected");stopPolling()};
  socket.onmessage=evt=>{try{ingest(JSON.parse(evt.data));setStatus("good","Live · WS",allVehicles.length+" vehicles")}catch(e){}};
  socket.onclose=()=>{clearTimeout(t);if(connMode==="ws"){setStatus("warn","WS closed","Reconnecting…");setTimeout(tryWS,5000)}};
  socket.onerror=()=>{clearTimeout(t);socket=null;startPolling()};
}

async function fetchVehicles(){
  if(!API_BASE||API_BASE.includes("YOUR-PROXY")){setStatus("bad","API_BASE not set","Edit the JS constant at top of script");return}
  setStatus("warn","Fetching…","Calling proxy");
  try{
    const t0=performance.now(),resp=await fetch(`${API_BASE}/vehicles`,{cache:"no-store"}),ms=Math.round(performance.now()-t0);
    if(!resp.ok){setStatus("bad","Fetch failed","HTTP "+resp.status);return}
    ingest(await resp.json());setStatus("good","Polling",allVehicles.length+" vehicles · "+ms+"ms");
  }catch(err){setStatus("bad","Error",err?.message??String(err))}
}
function startPolling(){if(connMode!=="poll"){setMode("poll");setStatus("warn","Polling","Push unavailable")}stopPolling();fetchVehicles();fetchTimer=setInterval(fetchVehicles,Number(els.refreshMs.value)||5000)}
function stopPolling(){if(fetchTimer){clearInterval(fetchTimer);fetchTimer=null}}
function scheduleLoop(){if(connMode==="poll")startPolling()}

function connect(){
  if(!API_BASE||API_BASE.includes("YOUR-PROXY")){setMode("error");setStatus("bad","API_BASE not set","Update the JS constant");els.apiLabel.textContent="⚠ not configured";return}
  els.apiLabel.textContent=API_BASE;setMode("boot");setStatus("warn","Connecting…","SSE → WS → poll");startSSE();
}

function wireUI(){
  let db;
  const dr=()=>{clearTimeout(db);db=setTimeout(render,120)};
  [els.routeId,els.vehicleId,els.tripId,els.quick].forEach(el=>el.addEventListener("input",dr));
  els.refreshMs.addEventListener("change",scheduleLoop);
  els.centerOnToronto.addEventListener("click",()=>map.setView(TORONTO,12));
  els.clearFilters.addEventListener("click",()=>{[els.routeId,els.vehicleId,els.tripId,els.quick].forEach(el=>el.value="");render()});
  els.fitToMarkers.addEventListener("click",()=>{try{const b=clusterGroup.getBounds();if(b.isValid())map.fitBounds(b.pad(.1))}catch(_){}});
}

const str=v=>(v??"").toString().trim();
const fmt=(n,d=5)=>typeof n==="number"?n.toFixed(d):"–";
function formatAge(ms){if(ms==null)return"–";const s=Math.max(0,Math.round(ms/1000));return s<60?s+"s":Math.round(s/60)+"m"}
function esc(s){return String(s??"").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#039;")}

(function boot(){initMap();wireUI();connect()})();
</script>
